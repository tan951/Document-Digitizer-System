{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Module3ExtractionOutput",
  "type": "object",
  "required": [
    "request_id",
    "document_id",
    "timestamp",
    "status",
    "payload"
  ],
  "properties": {
    "request_id": { "type": "string" },
    "document_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["success", "error"] },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "required": ["code", "message"]
    },
    "payload": {
      "type": "object",
      "required": ["document_type", "extracted_fields"],
      "properties": {
        "document_type": { "type": "string" },
        "extracted_fields": {
          "type": "object",
          "properties": {
            "fixed": {
              "type": "array",
              "items": { "$ref": "#/$defs/extracted_field" }
            },
            "dynamic": {
              "type": "array",
              "items": { "$ref": "#/$defs/extracted_field" }
            }
          }
        },
        "correction_log": {
          "type": ["object", "null"],
          "properties": {
            "enabled": { "type": "boolean" },
            "changes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["original", "corrected", "field"],
                "properties": {
                  "original": { "type": "string" },
                  "corrected": { "type": "string" },
                  "field": { "type": "string" }
                }
              }
            }
          },
          "required": ["enabled"]
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "extracted_field": {
      "type": "object",
      "required": ["field_name", "value", "confidence", "method"],
      "properties": {
        "field_name": { "type": "string" },
        "value": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "bbox": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "method": { "type": "string" }
      }
    }
  }
}